{
  "name": "gitmerge-review",
  "displayName": "GitMerge Review",
  "description": "Review GitHub Pull Requests and GitLab Merge Requests with side-by-side diff and AI analysis",
  "version": "0.1.16",
  "publisher": "gitmerge",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "github",
    "gitlab",
    "merge request",
    "pull request",
    "review",
    "diff",
    "ai",
    "copilot"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitmerge-review",
          "title": "GitMerge Review",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "gitmerge-review": [
        {
          "id": "mergeRequestExplorer",
          "name": "Merge Requests",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "gitmerge.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "gitmerge.openMR",
        "title": "Open Merge Request",
        "icon": "$(go-to-file)"
      },
      {
        "command": "gitmerge.setGithubToken",
        "title": "GitMerge: Set GitHub Token"
      },
      {
        "command": "gitmerge.setGitlabToken",
        "title": "GitMerge: Set GitLab Token"
      },
      {
        "command": "gitmerge.configure",
        "title": "GitMerge: Configure",
        "icon": "$(settings-gear)"
      },
      {
        "command": "gitmerge.showLog",
        "title": "GitMerge: Show Log"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitmerge.refresh",
          "when": "view == mergeRequestExplorer",
          "group": "navigation@1"
        },
        {
          "command": "gitmerge.configure",
          "when": "view == mergeRequestExplorer",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "gitmerge.openMR",
          "when": "view == mergeRequestExplorer && viewItem == mergeRequest",
          "group": "inline"
        },
        {
          "command": "gitmerge.setGithubToken",
          "when": "view == mergeRequestExplorer && viewItem == provider-github",
          "group": "inline"
        },
        {
          "command": "gitmerge.setGitlabToken",
          "when": "view == mergeRequestExplorer && viewItem == provider-gitlab",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "GitMerge Review",
      "properties": {
        "gitmerge.gitlabUrl": {
          "type": "string",
          "default": "https://gitlab.com",
          "description": "GitLab instance URL (change for self-hosted GitLab, e.g. https://mygitlab.company.com)"
        },
        "gitmerge.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Auto-refresh assigned merge requests periodically"
        },
        "gitmerge.refreshInterval": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "Auto-refresh interval in minutes"
        },
        "gitmerge.showMergedRequests": {
          "type": "boolean",
          "default": false,
          "description": "Also show merged/closed requests in the sidebar"
        },
        "gitmerge.aiModel": {
          "type": "string",
          "default": "gpt-4o",
          "enum": [
            "gpt-4o",
            "gpt-4",
            "claude-3-5-sonnet"
          ],
          "description": "AI model family to use for code analysis (requires GitHub Copilot)"
        },
        "gitmerge.aiLanguage": {
          "type": "string",
          "default": "English",
          "enum": [
            "English",
            "Indonesian",
            "Spanish",
            "French",
            "German",
            "Japanese",
            "Korean",
            "Chinese (Simplified)",
            "Portuguese",
            "Arabic"
          ],
          "enumDescriptions": [
            "English",
            "Bahasa Indonesia",
            "Español",
            "Français",
            "Deutsch",
            "日本語",
            "한국어",
            "中文（简体）",
            "Português",
            "العربية"
          ],
          "description": "Language for AI code analysis responses"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.7.1",
    "typescript": "^5.4.0"
  }
}
